---

---

<section class="relative pt-32 lg:pt-40 pb-20 lg:pb-32 overflow-hidden">
  <div class="section-padding">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left Content -->
      <div class="max-w-2xl">
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold text-dark leading-tight mb-6"
        >
          Potencia tus Ventas y Fideliza Clientes con <span class="text-primary"
            >InnovateCRM</span
          >
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 mb-8 leading-relaxed">
          La plataforma líder para gestionar tus relaciones y crecer tu negocio
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href="#prueba" class="btn-primary text-center text-lg">
            Empieza Tu Prueba Gratuita
          </a>
          <a
            href="#demo"
            class="btn-secondary text-center text-lg flex items-center justify-center gap-2"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Ver Demostración
          </a>
        </div>
        <p class="text-sm text-gray-500">
          Ver demostración until Prueba gratuita
        </p>
      </div>

      <!-- Right Content - Dashboard Image -->
      <div class="relative">
        <div
          class="relative bg-gradient-to-br from-primary/20 to-secondary/20 rounded-2xl p-4 lg:p-8"
        >
          <img
            src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop"
            alt="CRM Dashboard"
            class="rounded-xl shadow-2xl w-full"
          />

          <!-- Floating Elements -->
          <div
            class="absolute -top-4 -right-4 bg-white rounded-lg shadow-xl p-4 max-w-xs animate-pulse"
          >
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0"
              >
                <span class="text-green-600 text-lg">👋</span>
              </div>
              <div>
                <h4 class="font-semibold text-dark text-sm">
                  Características Clave
                </h4>
                <p class="text-xs text-gray-600 mt-1 leading-relaxed">
                  Potencia tus ventas al máximo con extensas características que
                  incluyen aumentando con marketing digital.
                </p>
                <div class="flex items-center gap-2 mt-2">
                  <img
                    src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=32&h=32&fit=crop&crop=face"
                    alt="Andrés"
                    class="w-6 h-6 rounded-full"
                  />
                  <div>
                    <p class="text-xs font-medium text-dark">Andrés Mares</p>
                    <p class="text-[10px] text-gray-500">
                      Consumer & Engin English
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom floating card -->
          <div
            class="absolute -bottom-6 -left-6 bg-dark-blue text-white rounded-lg shadow-xl p-4 max-w-xs hidden lg:block"
          >
            <h4 class="font-semibold text-sm mb-2">Testimonios de Clientes</h4>
            <p class="text-xs text-gray-300 leading-relaxed italic">
              "Testimonios viver o testimonios en que nuestra plataforma y us
              testimonios tu negocio"
            </p>
            <div class="flex items-center gap-2 mt-3">
              <img
                src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=32&h=32&fit=crop&crop=face"
                alt="Andrés"
                class="w-8 h-8 rounded-full"
              />
              <div>
                <p class="text-xs font-medium">Andrés Mares</p>
                <div class="flex gap-1">
                  {
                    [1, 2, 3, 4, 5].map(() => (
                      <svg
                        class="w-3 h-3 text-yellow-400"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
