---
const testimonials = [
  {
    id: 1,
    quote:
      "Testimonios viver o testimonios en que nuestra plataforma y us testimonios tu negocio",
    author: "Andrés Mares",
    role: "CEO & Founder",
    image:
      "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face",
    rating: 5,
  },
  {
    id: 2,
    quote:
      "La plataforma líder para gestionar tus relaciones y crecer tu negocio, timonios del software todo, sin amoea de Clientes",
    author: "María González",
    role: "Directora de Ventas",
    image:
      "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face",
    rating: 5,
  },
  {
    id: 3,
    quote:
      "InnovateCRM transformó completamente nuestra forma de gestionar clientes. Increíble herramienta.",
    author: "Carlos Ruiz",
    role: "Marketing Manager",
    image:
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop&crop=face",
    rating: 5,
  },
];
---

<section
  class="py-20 lg:py-32 bg-dark-blue text-white relative overflow-hidden"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute top-20 left-20 w-72 h-72 bg-primary rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-20 right-20 w-96 h-96 bg-secondary rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="section-padding relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold mb-4">
        Testimonios de Clientes
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Descubre por qué miles de empresas confían en InnovateCRM para hacer
        crecer su negocio
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {
        testimonials.map((testimonial) => (
          <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 transition-all duration-300">
            <div class="flex gap-1 mb-4">
              {[...Array(testimonial.rating)].map(() => (
                <svg
                  class="w-5 h-5 text-yellow-400"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <p class="text-gray-300 mb-6 italic leading-relaxed">
              "{testimonial.quote}"
            </p>

            <div class="flex items-center gap-4">
              <img
                src={testimonial.image}
                alt={testimonial.author}
                class="w-12 h-12 rounded-full object-cover border-2 border-primary"
              />
              <div>
                <h4 class="font-semibold text-white">{testimonial.author}</h4>
                <p class="text-sm text-gray-400">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Stats -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 max-w-4xl mx-auto text-center"
    >
      <div>
        <p class="text-4xl font-bold text-primary mb-2">10K+</p>
        <p class="text-gray-400 text-sm">Clientes Activos</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-primary mb-2">98%</p>
        <p class="text-gray-400 text-sm">Satisfacción</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-primary mb-2">50+</p>
        <p class="text-gray-400 text-sm">Países</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-primary mb-2">24/7</p>
        <p class="text-gray-400 text-sm">Soporte</p>
      </div>
    </div>
  </div>
</section>
